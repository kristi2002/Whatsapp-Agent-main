# ============================================================================
# Copy to .env.local and fill in. NEVER commit real secrets to this file.
# The previous values here were live credentials — they have been removed and
# MUST be rotated (Meta token, Supabase keys, Supabase MCP token in .mcp.json).
# ============================================================================

# Meta WhatsApp Business API
# NOTE: the access token is NOT in workflow.v3.json — copy it out of your n8n
# WhatsApp credential (Settings > Credentials) and paste it here.
WHATSAPP_ACCESS_TOKEN=        # Permanent access token (from n8n credential / Meta System User)
WHATSAPP_PHONE_NUMBER_ID=1142465592289974   # Max&Tony Nazionale — from workflow.v3.json
WHATSAPP_VERIFY_TOKEN=        # Any string you choose (e.g. "myverifytoken123") — used to verify the webhook
WHATSAPP_APP_SECRET=          # App Secret from Meta App > Settings > Basic — used to verify webhook signatures
STAFF_NOTIFY_NUMBER=393802871060   # WhatsApp number alerted on human handoff (from workflow.v3.json)

# AI Model (OpenRouter or OpenAI-compatible)
OPENROUTER_API_KEY=           # API key from openrouter.ai (in n8n OpenRouter credential)
AI_MODEL=google/gemini-2.5-flash   # Model used by the existing n8n workflow

# Supabase (self-hosted on Coolify, or Supabase Cloud)
NEXT_PUBLIC_SUPABASE_URL=     # e.g. https://xxxxx.supabase.co or your self-hosted URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # anon/public key (frontend)
SUPABASE_SERVICE_ROLE_KEY=       # service role key (backend/webhook) — keep secret

# Dashboard auth (staff login)
DASHBOARD_PASSWORD=           # Shared password staff type to access the dashboard
AUTH_SECRET=                  # Random string (min 16 chars) for signing session cookies — e.g. `openssl rand -hex 32`

# App Config
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
